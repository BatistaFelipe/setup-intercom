# Auto detect text files and perform LF normalization
* text=auto

# Source files
*.ts text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# Config files
.env text eol=lf
.gitignore text eol=lf
.nvmrc text eol=lf

# Lock files - treat as generated
package-lock.json -diff linguist-generated=true

# Compiled output
dist/ linguist-generated=true
