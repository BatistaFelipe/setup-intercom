{
  "compilerOptions": {
    "target": "ES2022",
    "strict": true,
    "paths": {
      "@/*": ["./src*"]
    },
    "outDir": "./dist",
    "rootDir": "./",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "declaration": true
  },
  "exclude": ["dist", "node_modules"]
}
